{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "gradleCommand": "assembleRelease",
        "env": {
          "EAS_BUILD_GRADLE_JAVA_VERSION": "21"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
